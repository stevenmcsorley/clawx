{
  "name": "@halfagiraf/clawx",
  "version": "0.4.94",
  "description": "Terminal-first coding agent — runs locally with Ollama, DeepSeek, OpenAI, or any OpenAI-compatible endpoint",
  "type": "module",
  "bin": {
    "clawx": "bin/clawx.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE",
    ".env.example",
    "clawx.json.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/main.js",
    "test": "vitest --run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevenmcsorley/clawx.git"
  },
  "homepage": "https://github.com/stevenmcsorley/clawx#readme",
  "bugs": {
    "url": "https://github.com/stevenmcsorley/clawx/issues"
  },
  "keywords": [
    "coding-agent",
    "ai-agent",
    "terminal",
    "cli",
    "ollama",
    "deepseek",
    "openai",
    "local-llm",
    "code-generation",
    "tool-calling",
    "ssh",
    "automation"
  ],
  "author": "Steven McSorley",
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@mariozechner/pi-agent-core": "^0.60.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@sinclair/typebox": "^0.34.0",
    "@swc/core": "^1.15.18",
    "@types/ws": "^8.18.1",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "google-protobuf": "^3.21.0",
    "ora": "^8.1.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
